{
  "splits_dir": "dataset/splits",
  "tokenizer_dir": "models/modernbert/tokenizer/sass-wordlevel-v1",
  "checkpoint_dir": "models/modernbert/checkpoints/sass-modernbert-compact-binary",
  "reports_dir": "experiments/results/reports/modernbert_binary",
  "label_column": "binary_label",
  "label2id": {
    "benign": 0,
    "mining": 1
  },
  "max_seq_length": 8192,
  "stride": 1024,
  "tokenizer": {
    "pad_token": "[PAD]",
    "unk_token": "[UNK]",
    "cls_token": "[CLS]",
    "sep_token": "[SEP]",
    "mask_token": "[MASK]",
    "min_frequency": 1
  },
  "modernbert": {
    "hidden_size": 384,
    "num_hidden_layers": 8,
    "num_attention_heads": 6,
    "intermediate_size": 576,
    "local_attention": 128,
